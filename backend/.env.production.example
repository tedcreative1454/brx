# Copy this file to backend/.env.production on your AWS server.
NODE_ENV=production
PORT=3000
APP_URL=https://brxp2p.com
FRONTEND_URL=https://brxp2p.com
PUBLIC_DOMAIN=brxp2p.com

POSTGRES_USER=brx
POSTGRES_DB=brx
POSTGRES_PASSWORD=change_this_database_password
DATABASE_URL=postgresql://brx:change_this_database_password@postgres:5432/brx
REDIS_URL=redis://redis:6379

RESEND_API_KEY=replace_me
RESEND_FROM_EMAIL=BRX <noreply@brxp2p.com>

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://brxp2p.com/api/auth/google/callback

# Cloudflare Turnstile server-side secret for signup/login.
TURNSTILE_SECRET_KEY=

ALCHEMY_BNB_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
BSC_USDT_CONTRACT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
BSC_CONFIRMATIONS_REQUIRED=15
BSC_MIN_DEPOSIT_USDT=1
BSC_LOG_BLOCK_RANGE=10
BSC_SCAN_LOOKBACK_BLOCKS=10
BSC_DEPOSIT_SCAN_INTERVAL_MS=30000
BSC_WITHDRAWAL_PROCESS_INTERVAL_MS=30000
BSC_WITHDRAWAL_CONFIRMATIONS_REQUIRED=15
WITHDRAWAL_BATCH_LIMIT=5
WALLET_WORKER_ENABLED=false
BSC_HOT_WALLET_PRIVATE_KEY=

JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_secret
ENCRYPTION_KEY=replace_me_32_byte_key