# BRX backend local environment
NODE_ENV=development
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
PUBLIC_DOMAIN=brxp2p.com

# Database / queue
DATABASE_URL=postgresql://brx:brx_password@localhost:5432/brx
REDIS_URL=redis://localhost:6379

# Email
RESEND_API_KEY=replace_me
# Use a sender on your verified Resend domain.
RESEND_FROM_EMAIL=BRX <noreply@brxp2p.com>

# Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# BNB Smart Chain / Alchemy
# Never expose this in frontend code. Put your full Alchemy URL here locally.
ALCHEMY_BNB_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
BSC_USDT_CONTRACT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
BSC_CONFIRMATIONS_REQUIRED=15
BSC_MIN_DEPOSIT_USDT=1
BSC_LOG_BLOCK_RANGE=10
BSC_SCAN_LOOKBACK_BLOCKS=10
BSC_DEPOSIT_SCAN_INTERVAL_MS=30000
BSC_WITHDRAWAL_PROCESS_INTERVAL_MS=30000
BSC_WITHDRAWAL_CONFIRMATIONS_REQUIRED=15
WITHDRAWAL_BATCH_LIMIT=5
WALLET_WORKER_ENABLED=false
# Set only on the backend worker machine. Never commit a real private key.
BSC_HOT_WALLET_PRIVATE_KEY=

# Auth/security
JWT_ACCESS_SECRET=replace_me_with_long_random_secret
JWT_REFRESH_SECRET=replace_me_with_long_random_secret
ENCRYPTION_KEY=replace_me_32_byte_key

