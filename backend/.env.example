# BRX backend local environment
NODE_ENV=development
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
PUBLIC_DOMAIN=brxp2p.com

# Database / queue
DATABASE_URL=postgresql://brx:brx_password@localhost:5432/brx
REDIS_URL=redis://localhost:6379

# Email
RESEND_API_KEY=replace_me
# Use a sender on your verified Resend domain.
RESEND_FROM_EMAIL=BRX <noreply@brxp2p.com>
ADMIN_ALERT_EMAILS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google sign-in
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Cloudflare Turnstile server-side secret. Leave blank to disable locally.
TURNSTILE_SECRET_KEY=

# BNB Smart Chain / Alchemy
# Never expose this in frontend code. Put your full Alchemy URL here locally.
ALCHEMY_BNB_RPC_URL=https://bnb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
BSC_USDT_CONTRACT_ADDRESS=0x55d398326f99059fF775485246999027B3197955
BSC_CONFIRMATIONS_REQUIRED=15
BSC_MIN_DEPOSIT_USDT=1
BSC_LOG_BLOCK_RANGE=10
BSC_SCAN_LOOKBACK_BLOCKS=10
BSC_DEPOSIT_SCAN_INTERVAL_MS=30000
BSC_WITHDRAWAL_PROCESS_INTERVAL_MS=30000
BSC_WITHDRAWAL_CONFIRMATIONS_REQUIRED=15
WITHDRAWAL_BATCH_LIMIT=5
WITHDRAWAL_AUTO_APPROVE_LIMIT_USDT=50
WITHDRAWAL_DAILY_PLATFORM_LIMIT_USDT=1000
WALLET_WORKER_ENABLED=false
BSC_SWEEP_ENABLED=false
BSC_SWEEP_MIN_USDT=1
BSC_SWEEP_GAS_BUFFER_MULTIPLIER=1.25
# Custody wallet setup:
# - BSC uses the same MetaMask account address format: 0x...
# - Put the public 0x address in *_ADDRESS.
# - Put the exported private key for that SAME MetaMask account in *_PRIVATE_KEY.
# - Never put seed/recovery words here. Never commit or share real private keys.
# - Cold wallet can be a Binance BEP20 deposit address; no private key is needed for Binance cold storage.
BSC_HOT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
BSC_GAS_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
BSC_COLD_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
BSC_HOT_WALLET_PRIVATE_KEY=replace_with_hot_wallet_private_key
BSC_GAS_WALLET_PRIVATE_KEY=replace_with_gas_wallet_private_key

# Auth/security
JWT_ACCESS_SECRET=replace_me_with_long_random_secret
JWT_REFRESH_SECRET=replace_me_with_long_random_secret
ENCRYPTION_KEY=replace_me_32_byte_key

# PWA Web Push. Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@brxp2p.com

